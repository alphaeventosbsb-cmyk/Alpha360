{
  "name": "alpha360-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@alpha360/dashboard",
    "dev:api": "npm run dev --workspace=@alpha360/api",
    "dev:pwa": "npm run dev --workspace=@alpha360/pwa",
    "build": "npm run build --workspace=@alpha360/dashboard",
    "build:api": "npm run build --workspace=@alpha360/api",
    "build:pwa": "npm run build --workspace=@alpha360/pwa",
    "start": "npm run start --workspace=@alpha360/dashboard",
    "start:api": "npm run start --workspace=@alpha360/api",
    "lint": "npm run lint --workspace=@alpha360/dashboard"
  },
  "repository": {
    "type": "git",
